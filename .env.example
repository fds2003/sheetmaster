# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Founder Product
NEXT_PUBLIC_STRIPE_PRODUCT_ID=your_stripe_product_or_price_id

# Email (Resend — formula backup from FormulaBuilder)
# https://resend.com — verify domain for production; onboarding@resend.dev works for testing only.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=SheetMaster <noreply@yourdomain.com>
